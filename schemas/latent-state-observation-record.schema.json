{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Latent State Observation Record",
  "description": "A method-bound record for observing latent model states without making causal claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "record_status",
    "observation_id",
    "created_at",
    "model_context",
    "observer",
    "observation_method",
    "inspection_scope",
    "observed_signals",
    "interpretation_boundary",
    "evidence_manifest",
    "storage_policy",
    "assertions",
    "review"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "record_type": {
      "type": "string",
      "const": "latent_state_observation"
    },
    "record_status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "validated",
        "rejected",
        "superseded"
      ]
    },
    "observation_id": {
      "type": "string",
      "pattern": "^lso-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "model_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_id",
        "inference_ref"
      ],
      "properties": {
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "model_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "checkpoint_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "inference_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "observer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observer_id",
        "observer_type"
      ],
      "properties": {
        "observer_id": {
          "type": "string",
          "minLength": 1
        },
        "observer_type": {
          "type": "string",
          "enum": [
            "human",
            "organization",
            "automated_system",
            "hybrid"
          ]
        },
        "tool_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "observation_method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "method_family"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "method_family": {
          "type": "string",
          "minLength": 1
        },
        "configuration_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "threshold_policy_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "inspection_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_refs",
        "token_refs",
        "component_refs"
      ],
      "properties": {
        "layer_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          }
        },
        "token_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          }
        },
        "component_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "context_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "observed_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signal_id",
          "label",
          "signal_type",
          "score",
          "confidence",
          "rank",
          "direction",
          "epistemic_status",
          "evidence_refs"
        ],
        "properties": {
          "signal_id": {
            "type": "string",
            "pattern": "^signal-[A-Za-z0-9._:-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "signal_type": {
            "type": "string",
            "enum": [
              "concept",
              "feature",
              "state",
              "anomaly",
              "pattern",
              "other"
            ]
          },
          "score": {
            "type": [
              "number",
              "null"
            ]
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "rank": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "direction": {
            "type": "string",
            "enum": [
              "activation",
              "suppression",
              "mixed",
              "unknown"
            ]
          },
          "epistemic_status": {
            "type": "string",
            "enum": [
              "observed",
              "interpreted",
              "tentative"
            ]
          },
          "interpretation": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "interpretation_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "method_dependence_note",
        "limitations"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "method_dependence_note": {
          "type": "string",
          "minLength": 1
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "evidence_type"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "activation_summary",
              "derived_feature",
              "ranked_readout",
              "visualization",
              "statistical_result",
              "external_artifact",
              "other"
            ]
          },
          "uri": {
            "type": [
              "string",
              "null"
            ]
          },
          "digest": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "storage_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_activations_stored",
        "derived_representations_stored",
        "retention_class",
        "access_scope"
      ],
      "properties": {
        "raw_activations_stored": {
          "type": "boolean"
        },
        "derived_representations_stored": {
          "type": "boolean"
        },
        "retention_class": {
          "type": "string",
          "enum": [
            "ephemeral",
            "time_limited",
            "retained",
            "external_policy"
          ]
        },
        "access_scope": {
          "type": "string",
          "enum": [
            "restricted",
            "auditor_only",
            "research_controlled",
            "public_metadata",
            "custom"
          ]
        },
        "policy_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "causal_claim_made",
        "intervention_performed",
        "downstream_effect_claimed"
      ],
      "properties": {
        "causal_claim_made": {
          "type": "boolean",
          "const": false
        },
        "intervention_performed": {
          "type": "boolean",
          "const": false
        },
        "downstream_effect_claimed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "pending",
            "completed",
            "disputed"
          ]
        },
        "reviewer_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_note": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
